{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pedteste1",
  "main": "dist/server/index.js",
  "compatibility_date": "2026-05-15",
  "assets": {
    "directory": "dist/client"
  },
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": ["dist/server/**/*.js"]
    }
  ],
  "build": {
    "command": "npm run build"
  },
  "observability": {
    "enabled": true
  }
}
